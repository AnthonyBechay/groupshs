generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user")
}

// ─── Recruitment ─────────────────────────────────────────────────────────────

model RecruitmentSubmission {
  id                String   @id @default(uuid())
  fullName          String   @map("full_name")
  dateOfBirth       String   @map("date_of_birth")
  schoolLevel       String   @map("school_level")
  memberPhone       String?  @map("member_phone")
  parentWereScouts  Boolean  @map("parent_were_scouts")
  parentScoutGroup  String?  @map("parent_scout_group")
  parentContactInfo String   @map("parent_contact_info")
  siblingsInGroup   Boolean  @map("siblings_in_group")
  siblingNames      String?  @map("sibling_names")
  otherComments     String?  @map("other_comments")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("recruitment_submission")
}

// ─── Units ───────────────────────────────────────────────────────────────────

model Unit {
  id       String @id @default(uuid())
  name     String // e.g. "Louveteaux 1", "Eclaireurs Aigle"
  unitType String @map("unit_type") // LOUVETEAUX, ECLAIREURS, ROUTIERS, CHEFS

  members    Member[]
  activities Activity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("unit")
}

// ─── Members ─────────────────────────────────────────────────────────────────

model Member {
  id          String   @id @default(uuid())
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  dateOfBirth String?  @map("date_of_birth")
  phone       String?
  role        String?  // SOU, SI, SP, CP, SE, CE, CHEF
  progression String?  // TENDREPATTES, 1_ETOILE, 2_ETOILES, TOTEMISE, PROMESSE, SECONDE_CLASSE, PREMIERE_CLASSE
  joinedAt    DateTime @default(now()) @map("joined_at")

  unitId String @map("unit_id")
  unit   Unit   @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("member")
}

// ─── Activities ──────────────────────────────────────────────────────────────

model Activity {
  id          String @id @default(uuid())
  title       String
  description String

  unitId String @map("unit_id")
  unit   Unit   @relation(fields: [unitId], references: [id])

  activityType    String  @default("OTHER") @map("activity_type") // CAMP, JOURNEE, TEMPS, MARCHE, OTHER
  startDate       DateTime @map("start_date")
  endDate         DateTime? @map("end_date")
  pickupTime      String?  @map("pickup_time")      // e.g. "08:00"
  dropoffTime     String?  @map("dropoff_time")     // e.g. "17:00"
  pickupLocation  String?  @map("pickup_location")
  dropoffLocation String?  @map("dropoff_location")
  location        String?                            // main activity location

  imageUrl   String?  @map("image_url")
  isUpcoming Boolean  @default(true) @map("is_upcoming")
  year       Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("activity")
}

// ─── News ────────────────────────────────────────────────────────────────────

model NewsArticle {
  id        String   @id @default(uuid())
  title     String
  summary   String
  content   String?  // optional longer content
  imageUrl  String?  @map("image_url")
  published Boolean  @default(true)
  date      DateTime @default(now())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("news_article")
}

// ─── Gallery ──────────────────────────────────────────────────────────────────

model GalleryPhoto {
  id       String @id @default(uuid())
  imageUrl String @map("image_url")
  caption  String?
  sortOrder Int   @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_photo")
}
